# Ornn Skills Environment Configuration
# Copy this file to .env.local and fill in your values

# LLM Provider API Keys
# Choose one or more providers to configure
ORNN_DEEPSEEK_API_KEY=your_deepseek_api_key_here
ORNN_OPENAI_API_KEY=your_openai_api_key_here
ORNN_ANTHROPIC_API_KEY=your_anthropic_api_key_here
ORNN_GOOGLE_API_KEY=your_google_api_key_here

# NPM Configuration (for publishing)
# Only needed if you want to publish packages
NPM_TOKEN=your_npm_token_here

# Optional: Custom LLM endpoint
# ORNN_CUSTOM_LLM_ENDPOINT=https://your-custom-llm-endpoint.com
# ORNN_CUSTOM_LLM_API_KEY=your_custom_llm_api_key_here
